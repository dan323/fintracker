{
  "name": "fintracker",
  "homepage": "https://dan323.github.io/fintracker",
  "version": "0.2.0",
  "private": true,
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "browser-fs-access": "^0.38.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.0.1",
    "rimraf": "^6.1.3",
    "typescript": "^5",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "clean:dist": "rimraf dist || rmdir /s /q dist",
    "predeploy": "npm run build",
    "deploy": "npx gh-pages -d dist",
    "test": "vitest --run --globals --environment jsdom",
    "eject": "echo \"eject is not supported with vite\" && exit 1",
    "check:sec": "npm audit --audit-level=high",
    "upgrade:node22": "npx -y npm-check-updates -u && npm install"
  },
  "engines": {
    "node": ">=22"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
